<?xml version="1.0" encoding="utf-8" ?>
<component name="PlayerScreen" extends="Group">
  <interface>
    <field id="channel"  type="assocarray" />
    <field id="channels" type="assocarray" />
    <field id="storage"  type="assocarray" />
  </interface>

  <script type="text/brightscript" uri="pkg:/source/screens/PlayerScreen.brs" />

  <children>
    <!-- Full-screen video -->
    <Video
      id="video"
      width="1920"
      height="1080"
      translation="[0, 0]"
      enableUI="false" />

    <!-- Info overlay (top-left) -->
    <Group id="infoOverlay" translation="[40, 40]" visible="false">
      <Rectangle
        id="infoBg"
        width="500"
        height="80"
        color="#00000088" />
      <Poster
        id="chLogo"
        width="120"
        height="68"
        translation="[8, 6]" />
      <Label
        id="chName"
        font="font:MediumBoldSystemFont"
        color="#FFFFFF"
        translation="[138, 10]"
        width="350" />
      <Label
        id="chCountry"
        font="font:SmallSystemFont"
        color="#A0A0A0"
        translation="[138, 46]"
        width="350" />
    </Group>

    <!-- Bottom program bar -->
    <Group id="progBar" translation="[0, 920]" visible="false">
      <Rectangle
        id="progBg"
        width="1920"
        height="160"
        color="#000000CC" />
      <Label
        id="progTitle"
        font="font:MediumBoldSystemFont"
        color="#FFFFFF"
        translation="[60, 20]"
        width="1800" />
      <Label
        id="progNext"
        font="font:SmallSystemFont"
        color="#A0A0A0"
        translation="[60, 58]"
        width="1800" />
      <!-- Progress bar -->
      <Rectangle
        id="progBgBar"
        width="1800"
        height="4"
        color="#333333"
        translation="[60, 100]" />
      <Rectangle
        id="progFill"
        width="0"
        height="4"
        color="#E50000"
        translation="[60, 100]" />
    </Group>

    <!-- Controls overlay -->
    <Group id="controlsOverlay" translation="[0, 0]" visible="false">
      <Rectangle
        id="ctrlBg"
        width="1920"
        height="1080"
        color="#00000066" />
      <Label
        id="ctrlChUp"
        text="▲  Canal anterior"
        font="font:MediumSystemFont"
        color="#FFFFFF"
        horizAlign="center"
        width="1920"
        translation="[0, 400]" />
      <Label
        id="ctrlChDown"
        text="▼  Canal siguiente"
        font="font:MediumSystemFont"
        color="#FFFFFF"
        horizAlign="center"
        width="1920"
        translation="[0, 460]" />
      <Label
        id="ctrlFav"
        text="*  Opciones"
        font="font:MediumSystemFont"
        color="#FFFFFF"
        horizAlign="center"
        width="1920"
        translation="[0, 520]" />
      <Label
        id="ctrlBack"
        text="Back  Volver"
        font="font:MediumSystemFont"
        color="#A0A0A0"
        horizAlign="center"
        width="1920"
        translation="[0, 580]" />
    </Group>

    <!-- Options menu -->
    <Rectangle
      id="optionsBg"
      width="360"
      height="240"
      color="#1A1A1A"
      translation="[780, 420]"
      visible="false" />
    <LabelList
      id="optionsMenu"
      width="360"
      itemSize="[360, 48]"
      itemSpacing="[0, 4]"
      translation="[780, 420]"
      visible="false"
      focusBitmapBlendColor="#E50000" />

    <!-- Buffering indicator -->
    <Label
      id="bufferingLabel"
      text="Cargando…"
      font="font:MediumBoldSystemFont"
      color="#FFFFFF"
      horizAlign="center"
      width="1920"
      translation="[0, 500]"
      visible="false" />
  </children>
</component>
