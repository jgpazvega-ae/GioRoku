<?xml version="1.0" encoding="utf-8" ?>
<component name="ChannelCard" extends="Group">
  <interface>
    <field id="itemContent"  type="node"  onChange="_render" />
    <field id="focusPercent" type="float" onChange="_onFocus" />
    <field id="width"        type="float" />
    <field id="height"       type="float" />
  </interface>
  <children>
    <!-- Card background -->
    <Rectangle id="cardBg" width="240" height="150" color="#0F1623" />
    <!-- Logo area (top 100px) -->
    <Poster id="logo" width="240" height="100" translation="[0, 0]"
            loadDisplayMode="scaleToFit" />
    <Rectangle id="logoFallback" width="240" height="100" translation="[0, 0]"
               visible="false" />
    <Label id="logoInit" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
           horizAlign="center" vertAlign="center"
           width="240" height="100" translation="[0, 0]" visible="false" />
    <!-- Channel name (bottom 50px) -->
    <Rectangle width="240" height="50" color="#0A0D14" translation="[0, 100]" />
    <Label id="name" text="" font="font:SmallBoldSystemFont" color="#FFFFFF"
           horizAlign="center" vertAlign="center"
           width="220" height="50" translation="[10, 100]" />
    <!-- Focus tint rendered last so it draws on top of all content -->
    <Rectangle id="focusBg" width="240" height="150" color="#CC1F1F" opacity="0" />
  </children>
  <script type="text/brightscript" uri="pkg:/components/ChannelCard.brs" />
</component>
