<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">

  <script type="text/brightscript" uri="pkg:/source/MainScene.brs" />

  <children>

    <!-- ===== Background ===== -->
    <Rectangle id="bg" width="1920" height="1080" color="#0A0A0A" />

    <!-- ===== Header ===== -->
    <Rectangle id="headerBar"    width="1920" height="120" color="#111111" />
    <Rectangle id="headerAccent" width="1920" height="4"   color="#E50000" />
    <Label id="brand" text="GioRoku" font="font:LargeBoldSystemFont"
           color="#E50000" translation="[56, 28]" />
    <Rectangle id="brandDiv" width="2" height="44" color="#2D2D2D" translation="[220, 22]" />
    <Label id="tab0" text="CANALES"    font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[248, 34]" />
    <Label id="tab1" text="PELÍCULAS"  font="font:MediumSystemFont"     color="#787878" translation="[404, 34]" />
    <Label id="tab2" text="CATEGORÍAS" font="font:MediumSystemFont"     color="#787878" translation="[595, 34]" />
    <Label id="tab3" text="GUÍA"       font="font:MediumSystemFont"     color="#787878" translation="[796, 34]" />
    <Label id="tab4" text="FAVORITOS"  font="font:MediumSystemFont"     color="#787878" translation="[892, 34]" />
    <Label id="tab5" text="BUSCAR"     font="font:MediumSystemFont"     color="#787878" translation="[1068, 34]" />
    <Label id="tab6" text="AJUSTES"    font="font:MediumSystemFont"     color="#787878" translation="[1199, 34]" />
    <Rectangle id="navUnderline" width="120" height="4" color="#E50000" translation="[248, 108]" />
    <!-- Live clock + date, like a cable set-top box -->
    <Label id="clock" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
           horizAlign="right" width="1872" translation="[0, 18]" />
    <Label id="status" text="Cargando…" font="font:SmallSystemFont" color="#787878"
           horizAlign="right" width="1872" translation="[0, 84]" />

    <!-- ===== VIEW: CANALES — thumbnail grid (left) ===== -->
    <Group id="viewHome" translation="[0, 124]" visible="true">
      <PosterGrid id="homeGrid" translation="[56, 16]"
        basePosterSize="[276, 155]" caption1NumLines="1" caption2NumLines="0"
        numColumns="4" numRows="4" itemSpacing="[18, 24]"
        drawFocusFeedback="true" focusFootprintBlendColor="#E50000" />
    </Group>

    <!-- ===== VIEW: PELÍCULAS — IMDb top + search (portrait posters) ===== -->
    <Group id="viewMovies" translation="[0, 124]" visible="false">
      <Label id="movTitle" text="Películas · Clásicos gratis (dominio público)" font="font:MediumBoldSystemFont"
             color="#FFFFFF" translation="[56, 4]" />
      <MiniKeyboard id="movKbd" translation="[56, 44]" />
      <Label id="movHelp" text="Escribe para buscar  ·  Atrás: ver pósters / volver"
             font="font:SmallSystemFont" color="#505050" translation="[56, 392]" />
      <PosterGrid id="moviesGrid" translation="[470, 8]"
        basePosterSize="[196, 290]" caption1NumLines="1" caption2NumLines="1"
        numColumns="6" numRows="2" itemSpacing="[18, 30]"
        drawFocusFeedback="true" focusFootprintBlendColor="#E50000" />
      <Label id="movEmpty" text="" font="font:MediumSystemFont" color="#505050"
             translation="[470, 40]" width="1394" visible="false" />
    </Group>

    <!-- ===== VIEW: CATEGORÍAS — same grid layout ===== -->
    <Group id="viewLive" translation="[0, 124]" visible="false">
      <PosterGrid id="catGrid" translation="[56, 16]"
        basePosterSize="[276, 155]" caption1NumLines="1" caption2NumLines="0"
        numColumns="4" numRows="4" itemSpacing="[18, 24]"
        drawFocusFeedback="true" focusFootprintBlendColor="#E50000" />
    </Group>

    <!-- ===== VIEW: GUÍA — cable-style channel grid with logos ===== -->
    <Group id="viewGuide" translation="[0, 124]" visible="false">
      <Label id="guideTitle" text="Guía de canales" font="font:MediumBoldSystemFont"
             color="#FFFFFF" translation="[56, 4]" />
      <MarkupList id="guideList" translation="[56, 50]"
        itemComponentName="GuideRow" itemSize="[1200, 92]" itemSpacing="[0, 4]"
        numRows="9" drawFocusFeedback="false" vertFocusAnimationStyle="fixedFocusWrap" />
    </Group>

    <!-- ===== VIEW: FAVORITOS — full width grid ===== -->
    <Group id="viewFav" translation="[0, 124]" visible="false">
      <Label id="favTitle" text="Mis Favoritos" font="font:MediumBoldSystemFont"
             color="#FFFFFF" translation="[56, 4]" />
      <PosterGrid id="favGrid" translation="[56, 52]"
        basePosterSize="[260, 146]" caption1NumLines="1" caption2NumLines="0"
        numColumns="6" numRows="4" itemSpacing="[16, 22]"
        drawFocusFeedback="true" focusFootprintBlendColor="#E50000" />
      <Label id="favEmpty"
        text="No tienes favoritos aún.&#10;Presiona * sobre un canal para agregarlo."
        font="font:MediumSystemFont" color="#505050"
        horizAlign="center" vertAlign="center"
        width="1808" height="560" translation="[56, 68]" visible="false" />
    </Group>

    <!-- ===== VIEW: BUSCAR ===== -->
    <Group id="viewSearch" translation="[0, 124]" visible="false">
      <MiniKeyboard id="kbd" translation="[56, 8]" />
      <Label id="searchHelp" text="Escribe para buscar  ·  Atrás: ver resultados / volver"
             font="font:SmallSystemFont" color="#505050" translation="[56, 356]" />
      <PosterGrid id="searchGrid" translation="[56, 390]"
        basePosterSize="[220, 124]" caption1NumLines="1"
        numColumns="7" numRows="3" itemSpacing="[16, 22]"
        drawFocusFeedback="true" focusFootprintBlendColor="#E50000" />
      <Label id="searchEmpty" text="" font="font:MediumSystemFont" color="#505050"
             translation="[56, 416]" width="1808" visible="false" />
    </Group>

    <!-- ===== VIEW: AJUSTES ===== -->
    <Group id="viewSettings" translation="[0, 124]" visible="false">
      <LabelList id="settingsList" translation="[56, 16]" width="520"
        itemSize="[520, 68]" itemSpacing="[0, 6]" textHorizAlign="left"
        color="#FFFFFF" focusBitmapBlendColor="#E50000" />
      <Rectangle id="settingsPanel" width="1200" height="820" color="#181818" translation="[636, 0]" />
      <Label id="settingsInfo" font="font:MediumSystemFont" color="#C0C0C0"
        translation="[668, 32]" width="1136" height="780" numLines="18" wrap="true" />
    </Group>

    <!-- ===== Persistent channel info panel (right side, shown for tabs 0-2) ===== -->
    <!-- Sits to the right of the grid/list at x=1300, below the header. -->
    <Group id="infoPanel" translation="[1300, 124]" visible="false">
      <Rectangle id="infoPanelBg"  width="580" height="956" color="#141414" />
      <!-- Logo area -->
      <Rectangle id="infoLogoBg"   width="580" height="326" color="#1C1C1C" />
      <Poster    id="infoLogo"     width="520" height="293" translation="[30, 16]" />
      <!-- Channel-number bug, top-left corner of the logo area -->
      <Rectangle id="infoNumBg"    width="104" height="42" color="#E50000" translation="[30, 16]" />
      <Label     id="infoNum"      text="" font="font:SmallBoldSystemFont" color="#FFFFFF"
                 horizAlign="center" vertAlign="center" width="104" height="42" translation="[30, 16]" />
      <!-- Divider below logo -->
      <Rectangle id="infoDivider"  width="520" height="2"   color="#2D2D2D" translation="[30, 340]" />
      <!-- Channel info text -->
      <Label id="infoName"  text="Selecciona un canal"
             font="font:LargeBoldSystemFont" color="#FFFFFF"
             translation="[30, 358]" width="520" numLines="2" wrap="true" />
      <Label id="infoBadge" text="● EN VIVO"
             font="font:SmallBoldSystemFont" color="#E50000"
             translation="[30, 432]" />
      <Label id="infoMeta"  text=""
             font="font:SmallSystemFont" color="#909090"
             translation="[30, 462]" width="520" numLines="2" wrap="true" />
      <!-- Bottom hint -->
      <Label id="infoHint"  text="OK: Ver canal   *: Favoritos"
             font="font:SmallSystemFont" color="#383838"
             translation="[30, 900]" />
    </Group>

    <!-- ===== OVERLAY: Player ===== -->
    <Group id="viewPlayer" visible="false">
      <Video id="video" width="1920" height="1080" enableUI="false" />

      <!-- Cable set-top style zap banner (bottom of screen, auto-hides) -->
      <Group id="zapBanner" visible="false">
        <Rectangle id="zapBg"    width="1920" height="200" color="#0A0A0AF2" translation="[0, 852]" />
        <Rectangle id="zapTop"   width="1920" height="4"   color="#E50000"   translation="[0, 852]" />
        <!-- Channel-number dial block -->
        <Rectangle id="zapNumBg" width="210" height="120" color="#E50000" translation="[56, 892]" />
        <Label id="zapNum" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
               horizAlign="center" vertAlign="center" width="210" height="120" translation="[56, 892]" />
        <!-- Logo -->
        <Poster id="zapLogo" width="158" height="90" translation="[300, 907]" />
        <!-- Name + meta -->
        <Label id="zapName" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
               translation="[484, 894]" width="1100" />
        <Label id="zapMeta" text="" font="font:MediumSystemFont" color="#B0B0B0"
               translation="[486, 958]" width="1100" />
        <!-- Clock + hint, right side -->
        <Label id="zapClock" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
               horizAlign="right" width="1824" translation="[0, 900]" />
        <Label id="zapHint" text="" font="font:SmallSystemFont" color="#707070"
               horizAlign="right" width="1824" translation="[0, 1004]" />
      </Group>

      <!-- Quick channel guide while watching (video keeps playing behind it) -->
      <Group id="miniGuide" visible="false">
        <Rectangle id="miniBg"  width="640" height="1080" color="#0A0A0AF2" />
        <Rectangle id="miniBar" width="4"   height="1080" color="#E50000" translation="[640, 0]" />
        <Rectangle id="miniHdr" width="640" height="4" color="#E50000" translation="[0, 84]" />
        <Label id="miniTitle" text="GUÍA RÁPIDA" font="font:MediumBoldSystemFont"
               color="#FFFFFF" translation="[36, 36]" />
        <Label id="miniClock" text="" font="font:MediumBoldSystemFont" color="#787878"
               horizAlign="right" width="604" translation="[0, 38]" />
        <LabelList id="miniList" width="568" itemSize="[568, 58]" itemSpacing="[0, 2]"
          translation="[36, 104]" numRows="15" textHorizAlign="left"
          color="#D8D8D8" focusBitmapBlendColor="#E50000" />
        <Label id="miniHint" text="OK: Ver   ▲▼: Mover   Atrás: Cerrar"
               font="font:SmallSystemFont" color="#606060" translation="[36, 1024]" />
      </Group>

      <Label id="playerMsg" text="" font="font:MediumBoldSystemFont" color="#FFFFFF"
        horizAlign="center" vertAlign="center" width="1920" height="1080" visible="false" />
    </Group>

    <!-- ===== OVERLAY: Context menu ===== -->
    <Rectangle id="ctxBg" width="440" height="248" color="#1C1C1C"
               translation="[740, 416]" visible="false" />
    <LabelList id="ctxMenu" width="440" itemSize="[440, 60]" itemSpacing="[0, 4]"
      translation="[740, 420]" textHorizAlign="center"
      focusBitmapBlendColor="#E50000" visible="false" />

    <!-- ===== Full-screen status message ===== -->
    <Label id="message" text="" font="font:MediumSystemFont" color="#505050"
      horizAlign="center" vertAlign="center"
      width="1920" height="820" translation="[0, 130]" visible="false" />

  </children>
</component>
