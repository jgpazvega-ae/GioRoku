<?xml version="1.0" encoding="utf-8" ?>
<component name="SplashScreen" extends="Group">
  <interface>
    <field id="result" type="assocarray" />
    <field id="done"   type="boolean" value="false" />
  </interface>
  <children>
    <Rectangle width="1920" height="1080" color="#0A0D14" />
    <!-- G mark block -->
    <Rectangle width="90" height="90" color="#CC1F1F" translation="[870, 340]" />
    <Label text="G" font="font:LargeBoldSystemFont" color="#FFFFFF"
           horizAlign="center" vertAlign="center"
           width="90" height="90" translation="[870, 340]" />
    <!-- Wordmark -->
    <Label text="GIO" font="font:LargeBoldSystemFont" color="#FFFFFF"
           translation="[982, 348]" />
    <Label text="ROKU" font="font:MediumBoldSystemFont" color="#CC1F1F"
           translation="[982, 415]" />
    <!-- Tagline -->
    <Label text="Tu televisión latina" font="font:SmallSystemFont" color="#6B7280"
           translation="[840, 480]" width="240" horizAlign="center" />
    <!-- Accent line -->
    <Rectangle width="320" height="3" color="#CC1F1F" translation="[800, 520]" />
    <!-- Progress bar track -->
    <Rectangle width="960" height="3" color="#1A1F2E" translation="[480, 580]" />
    <Rectangle id="progressBar" width="0" height="3" color="#CC1F1F" translation="[480, 580]" />
    <Label id="statusLabel" text="Iniciando…" font="font:SmallSystemFont" color="#9CA3AF"
           translation="[480, 598]" width="960" horizAlign="center" />
  </children>
  <script type="text/brightscript" uri="pkg:/components/SplashScreen.brs" />
</component>
