<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/source/MainScene.brs" />
  <children>

    <!-- Background — deep navy-charcoal (cable/satellite aesthetic) -->
    <Rectangle id="bg" width="1920" height="1080" color="#111827" />

    <!-- ===== Header (120px) ===== -->
    <Rectangle id="headerBar" width="1920" height="120" color="#0A0D14" />
    <Rectangle id="brandAccent" width="4" height="50" color="#CC1F1F" translation="[44, 25]" />
    <Label id="brand" text="GioRoku" font="font:LargeBoldSystemFont"
           color="#FFFFFF" translation="[56, 28]" />
    <!-- Active-tab pill — slides behind the focused tab label (starts on GUÍA) -->
    <Rectangle id="navUnderline" width="60" height="28" color="#CC1F1F" translation="[593, 36]" />
    <!-- Tab labels — SmallBoldSystemFont so all 7 fit without cramping -->
    <Label id="tab0" text="EN VIVO"    font="font:SmallBoldSystemFont" color="#9CA3AF" translation="[234, 42]" />
    <Label id="tab1" text="PELÍCULAS"  font="font:SmallBoldSystemFont" color="#9CA3AF" translation="[340, 42]" />
    <Label id="tab2" text="CATEGORÍAS" font="font:SmallBoldSystemFont" color="#9CA3AF" translation="[461, 42]" />
    <Label id="tab3" text="GUÍA"       font="font:SmallBoldSystemFont" color="#FFFFFF" translation="[599, 42]" />
    <Label id="tab4" text="FAVORITOS"  font="font:SmallBoldSystemFont" color="#9CA3AF" translation="[675, 42]" />
    <Label id="tab5" text="BUSCAR"     font="font:SmallBoldSystemFont" color="#9CA3AF" translation="[803, 42]" />
    <Label id="tab6" text="AJUSTES"    font="font:SmallBoldSystemFont" color="#9CA3AF" translation="[904, 42]" />
    <!-- Header separator line -->
    <Rectangle id="headerAccent" width="1920" height="2" color="#2D3748" translation="[0, 118]" />
    <!-- Clock + date/status (right side) -->
    <Label id="clock" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
           horizAlign="right" width="1872" translation="[0, 18]" />
    <Label id="status" text="Cargando…" font="font:SmallSystemFont" color="#6B7280"
           horizAlign="right" width="1872" translation="[0, 80]" />

    <!-- ===== VIEW: EN VIVO — channel grid with names ===== -->
    <Group id="viewHome" translation="[0, 120]" visible="false">
      <PosterGrid id="homeGrid" translation="[48, 12]"
        basePosterSize="[290, 163]" caption1NumLines="1" caption2NumLines="0"
        numColumns="6" numRows="3" itemSpacing="[18, 14]"
        drawFocusFeedback="true" focusFootprintBlendColor="#CC1F1F" />
    </Group>

    <!-- ===== VIEW: PELÍCULAS ===== -->
    <Group id="viewMovies" translation="[0, 120]" visible="false">
      <Label id="movTitle" text="PELÍCULAS  ·  Clásicos de dominio público"
             font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[48, 8]" />
      <MiniKeyboard id="movKbd" translation="[48, 48]" />
      <Label id="movHelp" text="Escribe para buscar  ·  Atrás: pósters / volver"
             font="font:SmallSystemFont" color="#6B7280" translation="[48, 396]" />
      <PosterGrid id="moviesGrid" translation="[468, 8]"
        basePosterSize="[196, 290]" caption1NumLines="1" caption2NumLines="1"
        numColumns="6" numRows="2" itemSpacing="[18, 30]"
        drawFocusFeedback="true" focusFootprintBlendColor="#CC1F1F" />
      <Label id="movEmpty" text="" font="font:MediumSystemFont" color="#6B7280"
             translation="[468, 44]" width="1404" visible="false" />
    </Group>

    <!-- ===== VIEW: CATEGORÍAS ===== -->
    <Group id="viewLive" translation="[0, 120]" visible="false">
      <PosterGrid id="catGrid" translation="[48, 12]"
        basePosterSize="[290, 163]" caption1NumLines="1" caption2NumLines="0"
        numColumns="6" numRows="3" itemSpacing="[18, 14]"
        drawFocusFeedback="true" focusFootprintBlendColor="#CC1F1F" />
    </Group>

    <!-- ===== VIEW: GUÍA — full-width cable-style channel guide (default) ===== -->
    <Group id="viewGuide" translation="[0, 120]" visible="true">
      <Label id="guideTitle" text="GUÍA DE CANALES" font="font:SmallBoldSystemFont"
             color="#6B7280" translation="[48, 8]" />
      <MarkupList id="guideList" translation="[48, 40]"
        itemComponentName="GuideRow" itemSize="[1824, 80]" itemSpacing="[0, 2]"
        numRows="11" drawFocusFeedback="false" vertFocusAnimationStyle="fixedFocusWrap" />
    </Group>

    <!-- ===== VIEW: FAVORITOS ===== -->
    <Group id="viewFav" translation="[0, 120]" visible="false">
      <Label id="favTitle" text="FAVORITOS" font="font:MediumBoldSystemFont"
             color="#FFFFFF" translation="[48, 8]" />
      <PosterGrid id="favGrid" translation="[48, 52]"
        basePosterSize="[276, 155]" caption1NumLines="1" caption2NumLines="0"
        numColumns="6" numRows="4" itemSpacing="[18, 22]"
        drawFocusFeedback="true" focusFootprintBlendColor="#CC1F1F" />
      <Label id="favEmpty"
        text="No tienes favoritos aún.&#10;Presiona * sobre un canal para agregarlo."
        font="font:MediumSystemFont" color="#6B7280"
        horizAlign="center" vertAlign="center"
        width="1824" height="900" translation="[48, 60]" visible="false" />
    </Group>

    <!-- ===== VIEW: BUSCAR ===== -->
    <Group id="viewSearch" translation="[0, 120]" visible="false">
      <MiniKeyboard id="kbd" translation="[48, 8]" />
      <Label id="searchHelp" text="Escribe para buscar  ·  Atrás: ver resultados / volver"
             font="font:SmallSystemFont" color="#6B7280" translation="[48, 356]" />
      <PosterGrid id="searchGrid" translation="[48, 390]"
        basePosterSize="[220, 124]" caption1NumLines="1"
        numColumns="7" numRows="3" itemSpacing="[16, 22]"
        drawFocusFeedback="true" focusFootprintBlendColor="#CC1F1F" />
      <Label id="searchEmpty" text="" font="font:MediumSystemFont" color="#6B7280"
             translation="[48, 420]" width="1824" visible="false" />
    </Group>

    <!-- ===== VIEW: AJUSTES ===== -->
    <Group id="viewSettings" translation="[0, 120]" visible="false">
      <LabelList id="settingsList" translation="[48, 16]" width="520"
        itemSize="[520, 68]" itemSpacing="[0, 6]" textHorizAlign="left"
        color="#FFFFFF" focusBitmapBlendColor="#CC1F1F" />
      <Rectangle id="settingsPanel" width="1240" height="820" color="#1A1F2E" translation="[620, 0]" />
      <Label id="settingsInfo" font="font:MediumSystemFont" color="#9CA3AF"
        translation="[652, 32]" width="1176" height="780" numLines="18" wrap="true" />
    </Group>

    <!-- ===== Bottom info bar (EN VIVO and CATEGORÍAS tabs) ===== -->
    <Group id="infoPanel" translation="[0, 874]" visible="false">
      <Rectangle id="infoPanelBg" width="1920" height="206" color="#0A0D14" />
      <Rectangle id="infoTopLine" width="1920" height="2"   color="#2D3748" />
      <!-- Channel-number block -->
      <Rectangle id="infoNumBg" width="100" height="78" color="#CC1F1F" translation="[48, 30]" />
      <Label     id="infoNum"   text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
                 horizAlign="center" vertAlign="center" width="100" height="78" translation="[48, 30]" />
      <!-- Logo -->
      <Poster    id="infoLogo"  width="158" height="89" translation="[168, 28]" />
      <!-- Name / badge / meta -->
      <Label id="infoName"  text="Selecciona un canal"
             font="font:LargeBoldSystemFont" color="#FFFFFF"
             translation="[352, 22]" width="1300" />
      <Label id="infoBadge" text=""
             font="font:SmallBoldSystemFont" color="#CC1F1F"
             translation="[354, 86]" />
      <Label id="infoMeta"  text=""
             font="font:SmallSystemFont" color="#9CA3AF"
             translation="[354, 116]" width="1300" />
      <!-- Hint right -->
      <Label id="infoHint" text="OK: Ver canal   *: Favoritos"
             font="font:SmallSystemFont" color="#374151"
             horizAlign="right" width="1872" translation="[0, 168]" />
    </Group>

    <!-- ===== OVERLAY: Player ===== -->
    <Group id="viewPlayer" visible="false">
      <Video id="video" width="1920" height="1080" enableUI="false" />

      <!-- Cable STB zap banner -->
      <Group id="zapBanner" visible="false">
        <Rectangle id="zapBg"  width="1920" height="220" color="#0A0D14E6" translation="[0, 840]" />
        <Rectangle id="zapTop" width="1920" height="3"   color="#CC1F1F"   translation="[0, 840]" />
        <Rectangle id="zapNumBg" width="150" height="120" color="#CC1F1F" translation="[48, 878]" />
        <Label id="zapNum" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
               horizAlign="center" vertAlign="center" width="150" height="120" translation="[48, 878]" />
        <Poster id="zapLogo" width="170" height="96" translation="[220, 890]" />
        <Label id="zapName" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
               translation="[414, 876]" width="1220" />
        <Label id="zapMeta" text="" font="font:MediumSystemFont" color="#9CA3AF"
               translation="[416, 942]" width="1220" />
        <Label id="zapClock" text="" font="font:LargeBoldSystemFont" color="#FFFFFF"
               horizAlign="right" width="1872" translation="[0, 876]" />
        <Label id="zapHint"  text="" font="font:SmallSystemFont" color="#6B7280"
               horizAlign="right" width="1872" translation="[0, 1018]" />
      </Group>

      <!-- Quick channel guide overlay -->
      <Group id="miniGuide" visible="false">
        <Rectangle id="miniBg"  width="680" height="1080" color="#0A0D14F0" />
        <Rectangle id="miniBar" width="3"   height="1080" color="#CC1F1F" translation="[680, 0]" />
        <Rectangle id="miniHdr" width="680" height="3"    color="#CC1F1F" translation="[0, 82]" />
        <Label id="miniTitle" text="GUÍA RÁPIDA" font="font:MediumBoldSystemFont"
               color="#FFFFFF" translation="[36, 28]" />
        <Label id="miniClock" text="" font="font:MediumBoldSystemFont" color="#6B7280"
               horizAlign="right" width="644" translation="[0, 30]" />
        <LabelList id="miniList" width="608" itemSize="[608, 56]" itemSpacing="[0, 2]"
          translation="[36, 94]" numRows="16" textHorizAlign="left"
          color="#D8D8D8" focusBitmapBlendColor="#CC1F1F" />
        <Label id="miniHint" text="OK: Ver   ▲▼: Mover   Atrás: Cerrar"
               font="font:SmallSystemFont" color="#6B7280" translation="[36, 1032]" />
      </Group>

      <Label id="playerMsg" text="" font="font:MediumBoldSystemFont" color="#FFFFFF"
        horizAlign="center" vertAlign="center" width="1920" height="1080" visible="false" />
    </Group>

    <!-- ===== OVERLAY: Context menu ===== -->
    <Rectangle id="ctxBg" width="480" height="260" color="#1A1F2E"
               translation="[720, 400]" visible="false" />
    <LabelList id="ctxMenu" width="480" itemSize="[480, 64]" itemSpacing="[0, 4]"
      translation="[720, 404]" textHorizAlign="center"
      focusBitmapBlendColor="#CC1F1F" visible="false" />

    <!-- Full-screen status / error message -->
    <Label id="message" text="" font="font:MediumSystemFont" color="#6B7280"
      horizAlign="center" vertAlign="center"
      width="1920" height="820" translation="[0, 130]" visible="false" />

  </children>
</component>
